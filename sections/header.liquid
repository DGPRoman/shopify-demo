<header class="header full-width">
  <div class="header__inner">
    <h2 class="header__logo">
      {{ shop.name | link_to: routes.root_url }}
    </h2>

    <nav class="header__menu">
      {% for link in section.settings.menu.links %}
        {{ link.title | link_to: link.url }}
      {% endfor %}
    </nav>

    <div class="header__icons">
      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a href="{{ routes.cart_url }}">
        {% if cart.item_count > 0 %}
          <sup>{{ cart.item_count }}</sup>
        {% endif %}

        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>
    </div>
  </div>
</header>

{% stylesheet %}
  .header {
    display: grid;
    grid-template-columns: var(--content-grid);
    border-bottom: 1px solid var(--color-line);
  }
  .header__inner {
    grid-column: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 4.5rem;
  }
  .header__logo {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: var(--letter-spacing-logo);
    text-transform: uppercase;
  }
  .header__logo a {
    text-decoration: none;
    color: var(--color-foreground);
  }
  .header__menu {
    display: flex;
    gap: 1.5rem;
  }
  .header__menu a {
    font-size: 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
  }
  .header__menu a:hover {
    color: var(--color-foreground);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.4em;
  }
  .header__icons {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .header__icons a {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--color-foreground);
  }
  .header__icons a sup {
    position: absolute;
    left: 100%;
    overflow: hidden;
    max-width: var(--page-margin);
    font-size: var(--font-size-label);
  }
  .header__icons svg {
    width: 1.375rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
