# Copy to .env and fill in. NEVER commit .env — it is gitignored.

# Store domain, e.g. your-store.myshopify.com
SHOPIFY_STORE_DOMAIN=roman-pel.myshopify.com

# Credentials of the Dev Dashboard app (app page → Settings → Credentials).
# The app must be installed on the store and have these Admin API scopes:
#   read_products, write_products,
#   read_publications, write_publications,
#   read_online_store_navigation, write_online_store_navigation
# Scripts exchange these for a short-lived (24h) Admin API access token
# via the OAuth client credentials grant — no token is stored on disk.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
